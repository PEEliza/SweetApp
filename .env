# URL para cuando usas el Backend en la nube (Render)
EXPO_PUBLIC_API_URL=https://backsweet.onrender.com

# URL para cuando trabajas local (intercambia el '#' según lo que uses)
# Si usas emulador de Android: http://10.0.2.2:3000/api
# Si usas tu celular real con Expo Go: http://TU_IP_LOCAL:3000/api
# Si pruebas en entorno Web: http://localhost:3000/api

# Tiempo de espera máximo para las peticiones (opcional pero recomendado)
EXPO_PUBLIC_API_TIMEOUT=10000